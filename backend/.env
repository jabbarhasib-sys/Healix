# ── HEALIX AI — Local Environment ──────────────────────────────────────────
APP_NAME=HEALIX AI
APP_ENV=development
APP_PORT=8000
DEBUG=true
SECRET_KEY=dev-secret-healix-2026

# ── Ollama ──────────────────────────────────────────────────────────────────
# Use the model that is actually installed (qwen2.5-Coder:latest detected)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-Coder:latest
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# ── Cloud LLM (disabled by default) ─────────────────────────────────────────
USE_CLOUD_LLM=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./healix.db

# ── Redis (optional — comment out if not running) ────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=600

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_TIMEOUT=90
MAX_CONDITIONS=4
MAX_HOSPITALS=8
