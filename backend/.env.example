# ── App ────────────────────────────────────────────────────────
APP_NAME=HEALIX AI
APP_ENV=development
APP_PORT=8000
DEBUG=true
SECRET_KEY=changeme-use-openssl-rand-hex-32

# ── Ollama (PRIMARY LLM — FREE) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# ── Cloud LLM (OPTIONAL fallback) ──────────────────────────────
USE_CLOUD_LLM=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://healix:healix@localhost:5432/healix_db
# SQLite fallback for local dev (no Docker needed):
# DATABASE_URL=sqlite:///./healix.db

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=600

# ── ChromaDB ───────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chroma_db
CHROMA_COLLECTION=symptom_embeddings

# ── ML Models ──────────────────────────────────────────────────
ML_MODELS_PATH=./ml/saved_models
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# ── Pipeline ───────────────────────────────────────────────────
PIPELINE_TIMEOUT=90
MAX_CONDITIONS=4
MAX_HOSPITALS=8
CONFIDENCE_MIN=0.2
CONFIDENCE_MAX=0.95